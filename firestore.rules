rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny-all catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+%]+$');
    }

    function isValidUser(data) {
      return data.id == request.auth.uid
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256;
    }

    function isValidFavorite(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.showName is string && data.showName.size() > 0 && data.showName.size() <= 256
        && data.season >= 0
        && data.number >= 0
        && data.title is string && data.title.size() >= 0 && data.title.size() <= 256
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.userDisplayName is string && data.userDisplayName.size() > 0 && data.userDisplayName.size() <= 100
        && data.showName is string && data.showName.size() > 0 && data.showName.size() <= 256
        && data.season >= 0
        && data.number >= 0
        && data.rating >= 1.0 && data.rating <= 10.0
        && data.comment is string && data.comment.size() >= 0 && data.comment.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidCustomShow(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && (data.userId == 'guest' || (isAuthenticated() && data.userId == request.auth.uid))
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.seasons is number && data.seasons >= 1 && data.seasons <= 1000
        && data.episodesPerSeason is number && data.episodesPerSeason >= 1 && data.episodesPerSeason <= 25000
        && data.summary is string && data.summary.size() >= 0 && data.summary.size() <= 10000
        && data.genre is string && data.genre.size() >= 0 && data.genre.size() <= 256
        && data.premieredYear is string && data.premieredYear.size() <= 64
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidId(favoriteId) && request.resource.data.userId == request.auth.uid && isValidFavorite(request.resource.data);
      allow update: if isAuthenticated() && isValidId(favoriteId) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidFavorite(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidId(reviewId) && request.resource.data.userId == request.auth.uid && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && isValidId(reviewId) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidReview(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /custom_shows/{showId} {
      allow read: if true;
      allow create: if isValidId(showId) && isValidCustomShow(request.resource.data);
      allow update: if isValidId(showId) && (
        (resource.data.userId == 'guest' && request.resource.data.userId == 'guest') ||
        (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
      ) && isValidCustomShow(request.resource.data);
      allow delete: if (resource.data.userId == 'guest') || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
